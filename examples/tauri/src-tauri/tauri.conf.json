{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Evolu Tauri Example",
  "version": "0.1.0",
  "identifier": "dev.evolu.example.tauri",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Evolu Tauri Example",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
