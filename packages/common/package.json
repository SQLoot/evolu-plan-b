{
  "name": "@evolu/common",
  "version": "7.4.1",
  "description": "TypeScript library and local-first platform",
  "keywords": [
    "evolu",
    "local-first",
    "sqlite",
    "crdt",
    "e2ee"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": "evoluhq/evolu",
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "browser": "./dist/src/index.js",
      "react-native": "./dist/src/index.js"
    },
    "./local-first": {
      "types": "./dist/src/local-first/index.d.ts",
      "import": "./dist/src/local-first/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "local-first": [
        "./dist/src/local-first/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc",
    "build": "rimraf dist && tsc",
    "clean": "rimraf .turbo node_modules dist coverage test/tmp test/__screenshots__",
    "bench": "vitest bench"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "playwright": "^1.58.1",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "ws": "^8.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false
}
