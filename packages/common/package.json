{
  "name": "@evolu/common",
  "version": "7.4.1",
  "description": "TypeScript library and local-first platform",
  "keywords": [
    "evolu",
    "local-first",
    "sqlite",
    "crdt",
    "e2ee"
  ],
  "author": "Daniel Steigerwald <daniel@steigerwald.cz>",
  "license": "MIT",
  "repository": "evoluhq/evolu",
  "bugs": {
    "url": "https://github.com/evoluhq/evolu/issues"
  },
  "homepage": "https://evolu.dev",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/src/index.js",
      "browser": "./dist/src/index.js",
      "react-native": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./local-first": {
      "types": "./dist/src/local-first/index.d.ts",
      "source": "./src/local-first/index.ts",
      "import": "./dist/src/local-first/index.js",
      "default": "./dist/src/local-first/index.js"
    },
    "./polyfills": {
      "types": "./dist/src/Polyfills.d.ts",
      "source": "./src/Polyfills.ts",
      "import": "./dist/src/Polyfills.js",
      "default": "./dist/src/Polyfills.js"
    }
  },
  "typesVersions": {
    "*": {
      "polyfills": [
        "./dist/src/Polyfills.d.ts"
      ],
      "local-first": [
        "./dist/src/local-first/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/src/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "bun ../../scripts/rm.mts dist && tsc --build tsconfig.build.json",
    "prepack": "bun run build",
    "clean": "bun ../../scripts/rm.mts .turbo node_modules dist coverage test/tmp test/__screenshots__",
    "bench": "vitest bench --config ../../vitest.config.mts --passWithNoTests"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "kysely": "^0.28.12",
    "msgpackr": "^1.11.9",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "fast-check": "^4.6.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  }
}
